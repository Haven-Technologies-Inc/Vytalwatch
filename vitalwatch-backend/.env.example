# ============================================================
# VytalWatch AI - Backend Configuration
# Copy this file to .env and fill in the values
# ============================================================

# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=vitalwatch

# Redis (Required - session security, job queues, caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# InfluxDB (Time-series vital data)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=vitalwatch
INFLUXDB_BUCKET=vitals

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:3001/auth/microsoft/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:3001/auth/apple/callback

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Twilio (SMS/Voice)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# ZeptoMail (Transactional Email)
ZEPTOMAIL_TOKEN=
EMAIL_FROM=noreply@vytalwatch.ai
EMAIL_FROM_NAME=VytalWatch AI

# SMTP Fallback (Zoho)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@vytalwatch.ai
SMTP_FROM_NAME=VytalWatch AI

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# Grok AI
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1

# Tenovi Device Integration
TENOVI_API_KEY=
TENOVI_API_URL=https://api2.tenovi.com
TENOVI_CLIENT_DOMAIN=
TENOVI_WEBHOOK_SECRET=
TENOVI_WEBHOOK_AUTH_KEY=

# Encryption (AES-256 — must be exactly 32 characters)
ENCRYPTION_KEY=your-32-character-encryption-key!

# WebRTC TURN Server (self-hosted coturn)
TURN_SERVER_URL=turn:localhost:3478
TURN_USERNAME=vitalwatch
TURN_PASSWORD=VitalWatch2024!
TURN_REALM=vitalwatch.local
TURN_TTL=3600

# Session Security
SESSION_TIMEOUT_MINUTES=15
MAX_CONCURRENT_SESSIONS=3

# Auth Security (rate limiting, lockout)
SECURITY_MAX_FAILED_ATTEMPTS=5
SECURITY_LOCKOUT_DURATION_MINUTES=15
SECURITY_RATE_LIMIT_WINDOW_MINUTES=15
SECURITY_PASSWORD_HISTORY_COUNT=5

# Emergency Access
EMERGENCY_ACCESS_NOTIFY_EMAILS=admin@vytalwatch.ai
